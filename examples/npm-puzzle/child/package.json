{
  "name": "@item-analyzer/api",
  "version": "0.19.0",
  "description": "Standalone Item Analyzer API",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "rm -rf dist/ && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:int": "vitest run tests/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "migrate": "node dist/db/migrate.js && node dist/db/seeds/run.js",
    "migrate:generate": "drizzle-kit generate",
    "migrate:push": "drizzle-kit push",
    "seed": "node dist/db/seeds/run.js"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@aws-sdk/client-s3": "^3.971.0",
    "@aws-sdk/client-ssm": "^3.994.0",
    "@aws-sdk/s3-request-presigner": "^3.971.0",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.4.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^5.10.0",
    "koa": "^3.2.0",
    "koa-body": "^7.0.1",
    "koa2-swagger-ui": "^5.12.0",
    "pg": "^8.16.0",
    "pino": "^10.2.0",
    "pino-http": "^10.4.0",
    "zod": "^3.25.67",
    "@smithy/util-endpoints": "3.3.4"
  },
  "devDependencies": {
    "@types/koa": "^3.0.2",
    "@types/koa__cors": "^5.0.1",
    "@types/koa__router": "^12.0.4",
    "@types/node": "^25.0.9",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^6.0.3",
    "@vitest/ui": "^4.0.18",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
